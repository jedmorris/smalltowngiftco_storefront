# Shopify Storefront API (required)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=
SHOPIFY_REVALIDATION_SECRET=

# Shopify Admin API (server-only — never expose client-side, never prefix with NEXT_PUBLIC_)
# SHOPIFY_ADMIN_ACCESS_TOKEN is populated by `npm run admin:auth` after the one-time OAuth flow.
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_ADMIN_API_VERSION=2025-01

# Shopify Dev Dashboard app OAuth credentials (only needed to run `npm run admin:auth`)
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=
SHOPIFY_APP_OAUTH_PORT=3456

# Printify API (server-only). Token from Printify → My Profile → Connections.
# SOURCE = your Etsy-connected Printify shop (live catalog). TARGET = your Shopify-connected Printify shop (empty, fills during replicate).
PRINTIFY_API_TOKEN=
PRINTIFY_SOURCE_SHOP_ID=
PRINTIFY_TARGET_SHOP_ID=
# Optional override for the daily-sync revalidate target. Defaults to
# https://smalltowngiftco.vercel.app. Set to a custom domain if you point one
# at the Next.js Vercel deployment (NOT the Wix site at the apex smalltowngiftco.com).
VERCEL_DEPLOYMENT_URL=

# Site
NEXT_PUBLIC_SITE_URL=https://smalltowngiftco.com

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# Error Monitoring (optional)
NEXT_PUBLIC_SENTRY_DSN=
